# Set QTL tool
QTL_TOOL = config["eQTL"]["tool"]
CELL_TYPES = config["cell_types"]
CHROMOSOMES = list(range(1, 23)) + ["X"]

qtl_files = []

if QTL_TOOL == "fastqtl":
    for chunk in range(config["eQTL"]["num_chunks"]):
        qtl_files.append(config["output_files"]["fastqtl_output"].format(chunk=chunk))
        qtl_files.append(config["output_files"]["fastqtl_perm_output"].format(chunk=chunk)) 

elif QTL_TOOL == "tensorqtl":
    for cell_type in config["cell_types"]:
        qtl_files.append(config["output_files"]["tensorqtl_output"].format(cell_type=cell_type))
        qtl_files.append(config["output_files"]["tensorqtl_perm_output"].format(cell_type=cell_type))    
        qtl_files.append(config["output_files"]["tensorqtl_perm_log"].format(cell_type=cell_type))

def get_all_genes_from_checkpoint(wildcards):
    all_genes = []
    for cell_type in config["cell_types"]:
        # Access the checkpoint output for each cell_type
        # This will only be called after the checkpoint is complete
        coord_file = checkpoints.prep_exp_data.get(cell_type=cell_type).output.coord
        with open(coord_file, 'r') as f:
            # Skip header
            next(f)
            for line in f:
                parts = line.strip().split('\t')
                gene_id = parts[3] 
                all_genes.append(gene_id)
    return list(set(all_genes))

def aggregate_input(wildcards):
    checkpoint_output = checkpoints.get_gene_info.get(**wildcards).output[0]
    return expand(
        "../results/06TWAS/weights/{cell_type}/{gene_id}.RDat",
        sample = wildcards.cell_type,
        gene_id = glob_wildcards(os.path.join(checkpoint_output, "{gene_id}.txt")).gene_id,
    )

